{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://unpkg.com/vitepress-theme-neptu-blog/schema/site.schema.json",
  "title": "Neptu blog site config (site.yaml / _site.yaml)",
  "description": "Admin-editable site configuration for vitepress-theme-neptu-blog. Top-level VitePress locale identity + nested themeConfig block. Unknown keys are preserved — this schema is intentionally permissive and validates only the commonly-mistyped fields.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "lang": {
      "type": "string",
      "description": "IETF language tag for this locale, e.g. 'en-US', 'ru-RU', 'pt-BR'."
    },
    "title": {
      "type": "string",
      "description": "Site title for this locale. Defaults to themeConfig.blogTitle when omitted."
    },
    "titleTemplate": {
      "type": "string",
      "description": "Per-page title template. Use ':title' as placeholder."
    },
    "description": {
      "type": "string",
      "description": "Site description used for SEO meta tags and feeds."
    },
    "extends": {
      "type": "string",
      "description": "Per-locale file only. Name of another locale whose _site config is inherited as the base; current values override the parent."
    },
    "themeConfig": {
      "type": "object",
      "additionalProperties": true,
      "description": "Theme-specific configuration. Shape mirrors `ThemeConfig` from the theme types.",
      "properties": {
        "blogTitle": {
          "type": "string",
          "description": "Blog name. Used for SEO, tab titles and sidebar heading."
        },
        "perPage": {
          "type": "integer",
          "minimum": 1,
          "description": "Posts per page in archive/tag/author listings."
        },
        "similarPostsCount": { "type": "integer", "minimum": 0 },
        "sidebarTagsCount": { "type": "integer", "minimum": 0 },
        "paginationMaxItems": { "type": "integer", "minimum": 1 },
        "homeBgParallaxOffset": { "type": "integer" },
        "sidebarLogoSrc": { "type": "string" },
        "sidebarLogoHeight": { "type": "integer" },
        "repo": { "type": "string" },
        "twitterSite": { "type": "string" },
        "tagsBaseUrl": { "type": "string" },
        "archiveBaseUrl": { "type": "string" },
        "popularBaseUrl": { "type": "string" },
        "recentBaseUrl": { "type": "string" },
        "authorsBaseUrl": { "type": "string" },
        "externalLinkIcon": { "type": "boolean" },
        "seo": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "autoCanonical": { "type": "boolean" }
          }
        },
        "postFooter": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "author",
              "donate",
              "comments",
              "social-share",
              "edit-link",
              "tags",
              "similar",
              "popular-link"
            ]
          }
        },
        "postList": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "showDate": { "type": "boolean" },
            "showTags": { "type": "boolean" },
            "showThumbnail": { "type": "boolean" },
            "showPreview": { "type": "boolean" },
            "showAuthor": { "type": "boolean" },
            "maxPreviewLength": { "type": "integer", "minimum": 0 }
          }
        },
        "donate": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "url": { "type": "string" },
            "icon": { "type": "string" },
            "postDonateCall": { "type": "string" }
          }
        },
        "publisher": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string" },
            "logo": { "type": "string" }
          }
        },
        "authors": { "$ref": "./authors.schema.json" },
        "nav": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "donate": { "type": "boolean" },
            "links": { "type": "array", "items": { "$ref": "#/$defs/NavLink" } },
            "socialLinks": {
              "type": "array",
              "items": { "$ref": "#/$defs/SocialLink" }
            }
          }
        },
        "sidebar": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "recent": { "type": "boolean" },
            "popular": { "type": "boolean" },
            "archive": { "type": "boolean" },
            "authors": { "type": "boolean" },
            "tags": { "type": "boolean" },
            "donate": { "type": "boolean" },
            "rssFeed": { "type": "boolean" },
            "atomFeed": { "type": "boolean" },
            "blogTitle": { "type": ["boolean", "string"] },
            "links": { "type": "array", "items": { "$ref": "#/$defs/NavLink" } },
            "bottomLinks": {
              "type": "array",
              "items": { "$ref": "#/$defs/NavLink" }
            },
            "socialLinks": {
              "type": "array",
              "items": { "$ref": "#/$defs/SocialLink" }
            }
          }
        },
        "footer": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "message": { "type": "string" },
            "copyright": { "type": "string" },
            "links": { "type": "array", "items": { "$ref": "#/$defs/NavLink" } }
          }
        },
        "socialMediaShares": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name", "urlTemplate"],
            "properties": {
              "name": { "type": "string" },
              "icon": { "type": "string" },
              "title": { "type": "string" },
              "urlTemplate": { "type": "string" },
              "class": { "type": "string" }
            }
          }
        },
        "editLink": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "pattern": { "type": "string" },
            "text": { "type": "string" }
          }
        },
        "t": {
          "type": "object",
          "additionalProperties": true,
          "description": "Translation strings. Keys mirror the built-in I18n interface."
        }
      }
    }
  },
  "$defs": {
    "NavLink": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "text": { "type": "string" },
        "href": { "type": "string" },
        "link": { "type": "string" },
        "icon": { "type": "string" },
        "iconClass": { "type": "string" },
        "class": { "type": "string" },
        "mobileOnly": { "type": "boolean" },
        "desktopOnly": { "type": "boolean" },
        "header": { "type": "string" }
      }
    },
    "SocialLink": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "icon": { "type": "string" },
        "link": { "type": "string" },
        "url": { "type": "string" },
        "title": { "type": "string" },
        "class": { "type": "string" },
        "iconClass": { "type": "string" },
        "mobileOnly": { "type": "boolean" },
        "desktopOnly": { "type": "boolean" }
      }
    }
  }
}
