{
  "name": "my-neptu-blog",
  "version": "0.1.0",
  "private": true,
  "description": "Starter blog built with vitepress-theme-neptu-blog",
  "type": "module",
  "scripts": {
    "dev": "vitepress dev src",
    "build": "vitepress build src && pnpm pagefind",
    "pagefind": "pagefind --verbose --site ./src/.vitepress/dist --glob '**/*.html'",
    "preview": "vitepress preview src",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vitepress": "^2.0.0-alpha.18",
    "vitepress-theme-neptu-blog": "^0.19.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vue-tsc": "^3.0.0"
  }
}
