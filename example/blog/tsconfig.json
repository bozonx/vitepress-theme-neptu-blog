{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "vitepress-theme-neptu-blog": ["../../src/index.ts"],
      "vitepress-theme-neptu-blog/*": ["../../src/*"]
    }
  },
  "include": [
    "src/.vitepress/**/*.ts",
    "src/.vitepress/**/*.vue",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/env.d.ts",
    "../../src/**/*.ts",
    "../../src/**/*.vue"
  ]
}
