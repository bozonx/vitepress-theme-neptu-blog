{
  "name": "vitepress-theme-neptu-blog-example-blog",
  "version": "0.1.0",
  "description": "Example blog using vitepress-theme-neptu-blog",
  "type": "module",
  "author": "(Ivan Kozyrin <ipkozyrin@gmail.com>)",
  "license": "MIT",
  "scripts": {
    "dev": "vitepress dev src",
    "pagefind": "pagefind --verbose --site ./dist --glob '**/{post,page}*/*.html'",
    "build": "vitepress build src && pnpm pagefind",
    "preview": "vitepress preview src",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@midzer/tobii": "^2.5.0",
    "pagefind": "^1.4.0",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-theme-neptu-blog": "workspace:*",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/slug": "^11.0.0",
    "@types/cheerio": "^1.0.0",
    "@types/gray-matter": "^4.0.0",
    "@types/image-size": "^2.0.0",
    "@types/yaml": "^2.0.0",
    "cheerio": "^1.0.0",
    "feed": "^5.0.0",
    "googleapis": "^171.0.0",
    "gray-matter": "^4.0.0",
    "image-size": "^2.0.0",
    "rehype-external-links": "^3.0.0",
    "rehype-stringify": "^10.0.0",
    "remark": "^15.0.0",
    "remark-rehype": "^11.0.0",
    "slug": "^11.0.0",
    "strip-markdown": "^6.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.0",
    "vue-tsc": "^2.1.0",
    "yaml": "^2.0.0"
  }
}