{
  "name": "vitepress-theme-neptu-blog-example-blog",
  "version": "0.1.0",
  "description": "Example blog using vitepress-theme-neptu-blog",
  "type": "module",
  "author": "(Ivan Kozyrin <ipkozyrin@gmail.com>)",
  "license": "MIT",
  "scripts": {
    "dev": "vitepress dev src",
    "pagefind": "pagefind --verbose --site ./dist --glob '**/{post,page}*/*.html'",
    "build": "vitepress build src && pnpm pagefind",
    "preview": "vitepress preview src",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@midzer/tobii": "^3.2.0",
    "pagefind": "^1.5.2",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-theme-neptu-blog": "workspace:*",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^25.6.0",
    "cheerio": "^1.2.0",
    "feed": "^5.2.1",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "rehype-external-links": "^3.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "slug": "^11.0.1",
    "strip-markdown": "^6.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.7",
    "yaml": "^2.8.3"
  }
}