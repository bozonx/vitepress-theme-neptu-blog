{
  "name": "vitepress-theme-neptu-blog-example-blog",
  "version": "0.1.0",
  "description": "Example blog using vitepress-theme-neptu-blog",
  "type": "module",
  "author": "(Ivan Kozyrin <ipkozyrin@gmail.com>)",
  "license": "MIT",
  "scripts": {
    "dev": "vitepress dev src",
    "pagefind": "pagefind --verbose --site ./dist --glob '**/{post,page}*/*.html'",
    "build": "vitepress build src && pnpm pagefind",
    "preview": "vitepress preview src",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vitepress": "2.0.0-alpha.17",
    "vitepress-theme-neptu-blog": "workspace:*",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@types/cheerio": "^1.0.0",
    "@types/node": "^25.6.0",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.7"
  }
}