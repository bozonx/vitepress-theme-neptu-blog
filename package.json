{
  "name": "vitepress-theme-neptu-blog",
  "version": "0.19.0",
  "description": "VitePress custom theme for Neptu blog and other content sites: i18n, RSS, JSON-LD, hreflang, canonical, popular posts via GA, Pagefind, tags/archive/authors layouts.",
  "types": "src/types.d.ts",
  "type": "module",
  "author": "Ivan Kozyrin <ipkozyrin@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/bozonx/vitepress-theme-neptu-blog#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bozonx/vitepress-theme-neptu-blog.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/bozonx/vitepress-theme-neptu-blog/issues"
  },
  "files": [
    "src",
    "!src/.vitepress",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./src/types.d.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json",
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts"
    },
    "./configs": {
      "types": "./src/configs/index.ts",
      "import": "./src/configs/index.ts"
    },
    "./helpers": {
      "types": "./src/helpers.ts",
      "import": "./src/helpers.ts"
    },
    "./utils": {
      "types": "./src/utils/shared/index.ts",
      "import": "./src/utils/shared/index.ts"
    },
    "./utils/node": {
      "types": "./src/utils/node/index.ts",
      "import": "./src/utils/node/index.ts"
    },
    "./utils/client": {
      "types": "./src/utils/client/index.ts",
      "import": "./src/utils/client/index.ts"
    },
    "./layouts": {
      "types": "./src/layouts/index.ts",
      "import": "./src/layouts/index.ts"
    },
    "./list-helpers": {
      "types": "./src/list-helpers/index.ts",
      "import": "./src/list-helpers/index.ts"
    },
    "./list-helpers/node": {
      "types": "./src/list-helpers/node.ts",
      "import": "./src/list-helpers/node.ts"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "import": "./src/constants.ts"
    },
    "./transformers": {
      "types": "./src/transformers/index.ts",
      "import": "./src/transformers/index.ts"
    },
    "./composables": {
      "types": "./src/composables/index.ts",
      "import": "./src/composables/index.ts"
    },
    "./tailwind-source.css": "./src/styles/tailwind-source.css",
    "./blue-theme.css": "./src/styles/themes/blue.css",
    "./green-theme.css": "./src/styles/themes/green.css",
    "./purple-theme.css": "./src/styles/themes/purple.css",
    "./amber-theme.css": "./src/styles/themes/amber.css",
    "./teal-theme.css": "./src/styles/themes/teal.css",
    "./rose-theme.css": "./src/styles/themes/rose.css",
    "./magenta-theme.css": "./src/styles/themes/magenta.css",
    "./monochrome-theme.css": "./src/styles/themes/monochrome.css",
    "./theme-presets.css": "./src/styles/themes/theme-presets.css",
    "./pagefind-fix.css": "./src/styles/vendor/pagefind-fix.css",
    "./search-modal.css": "./src/styles/search-modal.css",
    "./configs/sharedLocalesBase/en": {
      "types": "./src/configs/sharedLocalesBase/en.ts",
      "import": "./src/configs/sharedLocalesBase/en.ts"
    },
    "./configs/sharedLocalesBase/ru": {
      "types": "./src/configs/sharedLocalesBase/ru.ts",
      "import": "./src/configs/sharedLocalesBase/ru.ts"
    },
    "./src/*": "./src/*"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0",
    "vitepress": "^2.0.0-alpha.18",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "scripts": {
    "generate:icons": "node scripts/generate-icon-bundle.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "pnpm exec playwright test --config tests/e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config tests/e2e/playwright.config.ts --ui",
    "e2e:report": "playwright show-report tests/e2e/playwright-report",
    "docs:dev": "pnpm --filter vitepress-theme-neptu-blog-docs dev",
    "docs:build": "pnpm --filter vitepress-theme-neptu-blog-docs build",
    "docs:preview": "pnpm --filter vitepress-theme-neptu-blog-docs preview"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "feed": "^6.0.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "jiti": "^2.7.0",
    "rehype-external-links": "^3.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "slug": "^12.0.1",
    "strip-markdown": "^6.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/cbi": "^1.2.47",
    "@iconify-json/cib": "^1.2.3",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/material-symbols": "^1.2.86",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.91",
    "@iconify-json/solar": "^1.2.5",
    "@iconify-json/vscode-icons": "^1.2.67",
    "@iconify/utils": "^3.1.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.11.0",
    "prettier": "^3.9.6",
    "prettier-plugin-jsdoc": "^1.8.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitepress": "2.0.0-alpha.18",
    "vitest": "^4.1.10",
    "vue": "^3.5.40",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.8"
  }
}
