    "type": "git",
    "url": "git+https://github.com/bozonx/vitepress-theme-neptu-blog.git"
  },
  "bugs": {
    "url": "https://github.com/bozonx/vitepress-theme-neptu-blog/issues"
  },

  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm dlx @tailwindcss/cli --minify -i ./src/styles/tailwind.css -o ./dist/tw-styles.css",
    "prepublishOnly": "pnpm run build"
  },
