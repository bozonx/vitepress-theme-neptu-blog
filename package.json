{
  "name": "vitepress-theme-neptu-blog",
  "version": "0.18.0",
  "description": "VitePress custom theme for Neptu blog and other content sites: i18n, RSS, JSON-LD, hreflang, canonical, popular posts via GA, Pagefind, tags/archive/authors layouts.",
  "types": "src/types.d.ts",
  "type": "module",
  "author": "Ivan Kozyrin <ipkozyrin@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/bozonx/vitepress-theme-neptu-blog#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bozonx/vitepress-theme-neptu-blog.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/bozonx/vitepress-theme-neptu-blog/issues"
  },
  "files": [
    "src",
    "!src/.vitepress",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./components": "./src/components/index.ts",
    "./configs": "./src/configs/index.ts",
    "./helpers": "./src/helpers.ts",
    "./utils": "./src/utils/shared/index.ts",
    "./utils/node": "./src/utils/node/index.ts",
    "./utils/client": "./src/utils/client/index.ts",
    "./layouts": "./src/layouts/index.ts",
    "./list-helpers": "./src/list-helpers/index.ts",
    "./list-helpers/node": "./src/list-helpers/node.ts",
    "./constants": "./src/constants.ts",
    "./transformers": "./src/transformers/index.ts",
    "./tailwind-source.css": "./src/styles/tailwind-source.css",
    "./blue-theme.css": "./src/styles/themes/blue.css",
    "./green-theme.css": "./src/styles/themes/green.css",
    "./purple-theme.css": "./src/styles/themes/purple.css",
    "./amber-theme.css": "./src/styles/themes/amber.css",
    "./teal-theme.css": "./src/styles/themes/teal.css",
    "./rose-theme.css": "./src/styles/themes/rose.css",
    "./magenta-theme.css": "./src/styles/themes/magenta.css",
    "./monochrome-theme.css": "./src/styles/themes/monochrome.css",
    "./pagefind-fix.css": "./src/styles/vendor/pagefind-fix.css",
    "./search-modal.css": "./src/styles/search-modal.css",
    "./configs/sharedLocalesBase/en": "./src/configs/sharedLocalesBase/en.ts",
    "./configs/sharedLocalesBase/ru": "./src/configs/sharedLocalesBase/ru.ts"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0",
    "vitepress": "^2.0.0-alpha.17",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@vueuse/components": "^14.2.1",
    "cheerio": "^1.2.0",
    "feed": "^5.2.1",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "rehype-external-links": "^3.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "slug": "^11.0.1",
    "strip-markdown": "^6.0.0",
    "yaml": "^2.8.3"
  },
  "scripts": {
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "^4.1.5",
    "vitest-browser-vue": "^2.1.0",
    "vue": "^3.5.33",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
