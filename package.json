{
  "name": "vitepress-theme-neptu-blog",
  "version": "0.18.0",
  "description": "VitePress custom theme for Neptu blog and other content sites: i18n, RSS, JSON-LD, hreflang, canonical, popular posts via GA, Pagefind, tags/archive/authors layouts.",
  "types": "src/types.d.ts",
  "type": "module",
  "author": "Ivan Kozyrin <ipkozyrin@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/bozonx/vitepress-theme-neptu-blog#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bozonx/vitepress-theme-neptu-blog.git"
  },
  "bugs": {
    "url": "https://github.com/bozonx/vitepress-theme-neptu-blog/issues"
  },

  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json",
    "./components": "./src/components/index.js",
    "./configs": "./src/configs/index.js",
    "./helpers": "./src/helpers/index.js",
    "./layouts": "./src/layouts/index.js",
    "./list-helpers": "./src/list-helpers/index.js",
    "./constants": "./src/constants.js",
    "./tailwind-source.css": "./src/styles/tailwind-source.css",
    "./blue-theme.css": "./src/styles/themes/blue.css",
    "./green-theme.css": "./src/styles/themes/green.css",
    "./pagefind-fix.css": "./src/styles/pagefind-fix.css",
    "./search-modal.css": "./src/styles/search-modal.css",
    "./site-theme-fix.css": "./src/styles/site-theme-fix.css"
  },
  "peerDependencies": {
    "vitepress": "^2.0.0-alpha.17",
    "vue": "^3.5.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": { "optional": true }
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@vueuse/components": "^14.2.1",
    "cheerio": "^1.0.0",
    "feed": "^5.0.0",
    "googleapis": "^171.0.0",
    "gray-matter": "^4.0.0",
    "image-size": "^2.0.0",
    "rehype-external-links": "^3.0.0",
    "rehype-stringify": "^10.0.0",
    "remark": "^15.0.0",
    "remark-rehype": "^11.0.0",
    "slug": "^11.0.0",
    "strip-markdown": "^6.0.0",
    "yaml": "^2.0.0"
  },
  "scripts": {
    "typecheck": "vue-tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.8.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.0",
    "vitepress": "2.0.0-alpha.17",
    "vue": "^3.5.32",
    "vue-tsc": "^2.1.0"
  }
}
