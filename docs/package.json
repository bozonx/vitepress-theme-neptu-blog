{
  "name": "vitepress-theme-neptu-blog-docs",
  "version": "0.1.0",
  "description": "Documentation and demo site using vitepress-theme-neptu-blog",
  "type": "module",
  "author": "(Ivan Kozyrin <ipkozyrin@gmail.com>)",
  "license": "MIT",
  "scripts": {
    "dev": "vitepress dev src",
    "pagefind": "pagefind --verbose --site ./src/.vitepress/dist --glob '**/*.html'",
    "build": "VITEPRESS_BASE=/vitepress-theme-neptu-blog/ vitepress build src --base /vitepress-theme-neptu-blog/ && pnpm pagefind",
    "preview": "vitepress preview src --base /vitepress-theme-neptu-blog/",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vitepress": "2.0.0-alpha.18",
    "vitepress-theme-neptu-blog": "workspace:*",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.0",
    "vue-tsc": "^3.3.7"
  }
}
