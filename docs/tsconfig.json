{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "jsx": "preserve",
    "strict": true,
    "noImplicitOverride": true,
    "useDefineForClassFields": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "vitepress-theme-neptu-blog": ["../src/index.ts"],
      "vitepress-theme-neptu-blog/*": ["../src/*"]
    }
  },
  "include": [
    "src/.vitepress/**/*.ts",
    "src/.vitepress/**/*.vue",
    "src/**/*.ts",
    "src/**/*.vue",
    "src/**/*.d.ts",
    "../src/**/*.ts",
    "../src/**/*.vue"
  ]
}

